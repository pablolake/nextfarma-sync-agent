# ── sync-agent · variables de entorno ───────────────────────────
# Corre en el PC de la farmacia (Windows). NUNCA commitees el .env real ni cronicos.db.

# SQL Server local de Farmatic (se resetearon credenciales al actualizar Farmatic → verificar)
DB_SERVER=localhost\\FARMATIC
DB_NAME=Farmatic
DB_USER=sa
DB_PASSWORD=

# API de Railway y clave del tenant (la da el alta de farmacia: POST /api/admin/tenants)
API_BASE_URL=https://nextfarma-api-production.up.railway.app
API_KEY=fxi_...

# Tenant (UUID) — opcional, informativo; el tenant real se resuelve desde API_KEY
TENANT_ID=

# Servidor local de crónicos (PII) y su tunnel
LOCAL_PORT=3001
